{
    "project_name": "MyVBAProject",

    "host_doc": "host/MacroHost.docm",
    "src_dir": "src",
    "fixtures_dir": "tests/fixtures",
    "expected_dir": "tests/expected",
    "results_dir": "results",

    "mutable_paths": [
        "src/"
    ],
    "immutable_paths": [
        "tests/",
        "harness/",
        "controller/",
        "project.json",
        "locked_paths.json"
    ],

    "controller": {
        "max_iterations": 5,
        "timeout_seconds": 60,
        "word_visible": false,
        "kill_on_timeout": true
    },

    "harness": {
        "entry_sub": "RunAllTests"
    }
}
